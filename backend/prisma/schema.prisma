generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TrainingStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum AnalysisStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum NormalizationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id            String         @id @default(cuid())
  nombre        String
  email         String         @unique
  password      String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  projects      Project[]
  refreshTokens RefreshToken[]
}

model Project {
  id          String    @id @default(cuid())
  userId      String
  name        String
  description String?
  user        User      @relation(fields: [userId], references: [id])
  datasets    Dataset[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Dataset {
  id               String        @id @default(cuid())
  projectId        String
  name             String
  description      String?
  originalFilename String?
  storageKey       String?
  mimeType         String?
  fileSize         Int?
  rows             Int?
  columns          Int?
  uploadedAt       DateTime?
  analysisStatus       AnalysisStatus      @default(PENDING)
  analysisError        String?
  normalizationStatus  NormalizationStatus @default(PENDING)
  normalizationError   String?
  normalizationFinishedAt DateTime?
  createdAt            DateTime            @default(now())
  updatedAt        DateTime      @updatedAt
  project          Project       @relation(fields: [projectId], references: [id])
  trainingJobs     TrainingJob[]
}

model TrainingJob {
  id                       String         @id @default(cuid())
  datasetId                String
  name                     String
  description              String?
  status                   TrainingStatus @default(QUEUED)
  progress                 Int            @default(0)
  gridWidth                Int
  gridHeight               Int
  neuronCount              Int
  alpha                    Float
  beta                     Float
  neighborhoodRadius       Float
  objectiveDimensionWeight Float
  useLogarithmicForget     Boolean        @default(false)
  threadCount              Int            @default(1)
  iterationLimit           Int?
  startedAt                DateTime?
  finishedAt               DateTime?
  errorMessage             String?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
  dataset                  Dataset        @relation(fields: [datasetId], references: [id])
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])
}
