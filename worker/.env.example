QUEUE_DRIVER=redis
REDIS_HOST=redis
REDIS_PORT=6379
QUEUE_NAME=som_jobs
TRAINING_QUEUE_NAME=training_jobs
LOG_LEVEL=INFO
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=/app/storage
BACKEND_URL=http://backend:3000
INTERNAL_API_KEY=your-internal-api-key-here
TRAINING_STATUS_POLL_INTERVAL_S=5
MAX_RECOVERY_ATTEMPTS=3

# AWS — required only when STORAGE_DRIVER=s3 or QUEUE_DRIVER=sqs
# AWS_REGION=sa-east-1
# AWS_S3_BUCKET=som-platform-storage
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# SQS — required only when QUEUE_DRIVER=sqs
# SQS_QUEUE_URL=https://sqs.sa-east-1.amazonaws.com/[account-id]/som-platform-jobs
# SQS_REGION=sa-east-1
